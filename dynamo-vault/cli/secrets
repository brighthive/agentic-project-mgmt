#!/usr/bin/env python3
"""
DynamoDB Workspace Vault CLI.

Query workspace/org configuration across BrightHive AWS accounts.

Usage:
    ./cli/secrets list-tables [--account STAGE]
    ./cli/secrets list [--account STAGE]
    ./cli/secrets fetch <workspace-name> [--account STAGE] [--show-secrets]
    ./cli/secrets search <query> [--account STAGE]
    ./cli/secrets export [--output data/index.json]
    ./cli/secrets diff <workspace> --accounts STAGE,PROD
"""

import sys
import json
import argparse
import logging
from pathlib import Path

# Add lib directory to path
lib_dir = Path(__file__).parent.parent / "lib"
sys.path.insert(0, str(lib_dir))

from config import AWS_ACCOUNTS
from dynamo_client import (
    list_tables,
    build_workspace_index,
    search_workspaces,
    get_workspace_by_name,
)
from indexer import build_index, write_index, generate_diff


def setup_logging(verbose: bool = False):
    """Configure logging."""
    level = logging.DEBUG if verbose else logging.WARNING
    logging.basicConfig(
        level=level,
        format="%(asctime)s [%(levelname)s] %(message)s",
        datefmt="%Y-%m-%d %H:%M:%S",
    )


def cmd_list_tables(args):
    """List DynamoDB tables in account(s)."""
    accounts = [args.account] if args.account else list(AWS_ACCOUNTS.keys())

    for account in accounts:
        print(f"\n📋 {account} Account ({AWS_ACCOUNTS[account]})")
        print("=" * 60)

        try:
            tables = list_tables(account_name=account)
            for i, name in enumerate(tables, 1):
                print(f"  {i:3}. {name}")
            print(f"\n  Total: {len(tables)} tables")
        except Exception as e:
            print(f"  ❌ Error: {e}")


def cmd_list(args):
    """List workspaces by name."""
    accounts = [args.account] if args.account else list(AWS_ACCOUNTS.keys())

    for account in accounts:
        print(f"\n📋 {account} Account — Workspaces")
        print("=" * 60)

        try:
            workspaces = build_workspace_index(account_name=account)
            if not workspaces:
                print("  No workspaces found.")
                continue

            for i, ws in enumerate(sorted(workspaces, key=lambda w: w.name), 1):
                type_icon = "🏢" if ws.entity_type.value == "Organization" else "🔧"
                secret_flag = " 🔑" if ws.env_secret_arn else ""
                print(f"  {i:3}. {type_icon} {ws.name}{secret_flag}")

            print(f"\n  Total: {len(workspaces)} workspaces/orgs")
        except Exception as e:
            print(f"  ❌ Error: {e}")


def cmd_fetch(args):
    """Fetch full config for a workspace."""
    account = args.account or "STAGE"

    print(f"🔍 Looking up '{args.workspace}' in {account}...")

    try:
        ws = get_workspace_by_name(
            account_name=account,
            workspace_name=args.workspace,
        )
        if not ws:
            print(f"❌ Workspace '{args.workspace}' not found in {account}")
            sys.exit(1)

        data = ws.to_dict(show_secrets=args.show_secrets)
        print(f"\n✅ {ws.name} ({ws.entity_type.value})")
        print("=" * 60)
        print(json.dumps(data, indent=2, default=str))

    except Exception as e:
        print(f"❌ Error: {e}")
        sys.exit(1)


def cmd_search(args):
    """Search workspaces by name substring."""
    account = args.account or "STAGE"

    print(f"🔍 Searching '{args.query}' in {account}...")

    try:
        matches = search_workspaces(account_name=account, query=args.query)
        if not matches:
            print(f"  No workspaces matching '{args.query}'")
            return

        for i, ws in enumerate(matches, 1):
            type_icon = "🏢" if ws.entity_type.value == "Organization" else "🔧"
            print(f"  {i}. {type_icon} {ws.name} (uuid={ws.uuid[:12]}...)")

        print(f"\n  {len(matches)} match(es)")
    except Exception as e:
        print(f"❌ Error: {e}")
        sys.exit(1)


def cmd_export(args):
    """Export full index to JSON + markdown."""
    account = args.account or "STAGE"
    output_dir = Path(args.output) if args.output else Path(__file__).parent.parent / "data"

    print(f"📤 Exporting workspace index from {account}...")

    try:
        workspaces = build_workspace_index(account_name=account)
        index = build_index(workspaces=workspaces, account_name=account)
        json_path, md_path = write_index(
            index=index,
            output_dir=output_dir,
            show_secrets=False,
        )
        print(f"✅ Wrote {len(workspaces)} workspaces")
        print(f"   JSON: {json_path}")
        print(f"   Markdown: {md_path}")
    except Exception as e:
        print(f"❌ Error: {e}")
        sys.exit(1)


def cmd_diff(args):
    """Compare workspace config across two environments."""
    accounts = [a.strip() for a in args.accounts.split(",")]
    if len(accounts) != 2:
        print("❌ --accounts requires exactly 2 comma-separated accounts (e.g. STAGE,PROD)")
        sys.exit(1)

    acc_a, acc_b = accounts
    print(f"🔍 Comparing '{args.workspace}' across {acc_a} vs {acc_b}...")

    try:
        ws_a = get_workspace_by_name(account_name=acc_a, workspace_name=args.workspace)
        ws_b = get_workspace_by_name(account_name=acc_b, workspace_name=args.workspace)

        if not ws_a and not ws_b:
            print(f"❌ '{args.workspace}' not found in either {acc_a} or {acc_b}")
            sys.exit(1)

        if not ws_a:
            print(f"⚠️  '{args.workspace}' exists in {acc_b} but NOT in {acc_a}")
            return

        if not ws_b:
            print(f"⚠️  '{args.workspace}' exists in {acc_a} but NOT in {acc_b}")
            return

        diff_lines = generate_diff(ws_a=ws_a, ws_b=ws_b)
        print("\n".join(diff_lines))

    except Exception as e:
        print(f"❌ Error: {e}")
        sys.exit(1)


def main():
    """CLI entry point."""
    parser = argparse.ArgumentParser(
        description="DynamoDB Workspace Vault — query workspace configs across AWS accounts"
    )
    parser.add_argument("-v", "--verbose", action="store_true", help="Verbose logging")

    subparsers = parser.add_subparsers(dest="command", help="Command to run")

    # list-tables
    lt_parser = subparsers.add_parser("list-tables", help="List DynamoDB tables")
    lt_parser.add_argument("--account", choices=list(AWS_ACCOUNTS.keys()), help="AWS account")

    # list
    list_parser = subparsers.add_parser("list", help="List workspaces")
    list_parser.add_argument("--account", choices=list(AWS_ACCOUNTS.keys()), help="AWS account")

    # fetch
    fetch_parser = subparsers.add_parser("fetch", help="Fetch workspace config")
    fetch_parser.add_argument("workspace", help="Workspace name (exact or partial)")
    fetch_parser.add_argument("--account", choices=list(AWS_ACCOUNTS.keys()), help="AWS account")
    fetch_parser.add_argument("--show-secrets", action="store_true", help="Show secret values unmasked")

    # search
    search_parser = subparsers.add_parser("search", help="Search workspaces by name")
    search_parser.add_argument("query", help="Search query (substring)")
    search_parser.add_argument("--account", choices=list(AWS_ACCOUNTS.keys()), help="AWS account")

    # export
    export_parser = subparsers.add_parser("export", help="Export index to JSON/markdown")
    export_parser.add_argument("--account", choices=list(AWS_ACCOUNTS.keys()), help="AWS account")
    export_parser.add_argument("--output", help="Output directory path")

    # diff
    diff_parser = subparsers.add_parser("diff", help="Compare workspace across environments")
    diff_parser.add_argument("workspace", help="Workspace name")
    diff_parser.add_argument("--accounts", required=True, help="Two accounts, comma-separated (e.g. STAGE,PROD)")

    args = parser.parse_args()
    setup_logging(verbose=args.verbose)

    if not args.command:
        parser.print_help()
        sys.exit(1)

    handlers = {
        "list-tables": cmd_list_tables,
        "list": cmd_list,
        "fetch": cmd_fetch,
        "search": cmd_search,
        "export": cmd_export,
        "diff": cmd_diff,
    }

    try:
        handlers[args.command](args)
    except KeyboardInterrupt:
        print("\nInterrupted.")
        sys.exit(130)
    except Exception as e:
        print(f"\n❌ Error: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
