<?xml version="1.0" encoding="utf-8"?>
<!--
  Loop Capital's morning holdings report — the SSRS report GC-14's Bar
  references ("before a portfolio manager asks why the SSRS report looks
  wrong"). This is the FIRST .rdl fixture in this org (confirmed by a prior
  audit: `find . -iname "*.rdl"` returned nothing repo-wide before this).
  Deliberately simple — a real Report Definition Language document an
  SSRS-diagnostics skill can parse, querying THIS sandbox's holdings_raw
  table, not a production-scale report.
-->
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition"
        xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">

  <DataSources>
    <DataSource Name="LoopCapitalAM">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=localhost;Initial Catalog=LoopCapitalAM</ConnectString>
      </ConnectionProperties>
    </DataSource>
  </DataSources>

  <DataSets>
    <DataSet Name="HoldingsDaily">
      <Query>
        <DataSourceName>LoopCapitalAM</DataSourceName>
        <CommandText>
          SELECT portfolio_id, instrument_id, quantity, as_of_date
          FROM dbo.holdings_raw
          WHERE as_of_date = CAST(GETDATE() AS DATE)
          ORDER BY portfolio_id, instrument_id;
        </CommandText>
      </Query>
      <Fields>
        <Field Name="portfolio_id">
          <DataField>portfolio_id</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="instrument_id">
          <DataField>instrument_id</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="quantity">
          <DataField>quantity</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="as_of_date">
          <DataField>as_of_date</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>

  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <Tablix Name="HoldingsTable">
            <TablixBody>
              <TablixColumns>
                <TablixColumn><Width>2in</Width></TablixColumn>
                <TablixColumn><Width>2in</Width></TablixColumn>
                <TablixColumn><Width>1.5in</Width></TablixColumn>
                <TablixColumn><Width>1.5in</Width></TablixColumn>
              </TablixColumns>
              <TablixRows>
                <TablixRow>
                  <Height>0.25in</Height>
                  <TablixCells>
                    <TablixCell><CellContents><Textbox Name="HeaderPortfolio"><Value>Portfolio</Value></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="HeaderInstrument"><Value>Instrument</Value></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="HeaderQuantity"><Value>Quantity</Value></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="HeaderAsOf"><Value>As Of</Value></Textbox></CellContents></TablixCell>
                  </TablixCells>
                </TablixRow>
                <TablixRow>
                  <Height>0.2in</Height>
                  <TablixCells>
                    <TablixCell><CellContents><Textbox Name="PortfolioId"><Value>=Fields!portfolio_id.Value</Value></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="InstrumentId"><Value>=Fields!instrument_id.Value</Value></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="Quantity"><Value>=Fields!quantity.Value</Value></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="AsOfDate"><Value>=Fields!as_of_date.Value</Value></Textbox></CellContents></TablixCell>
                  </TablixCells>
                </TablixRow>
              </TablixRows>
            </TablixBody>
            <DataSetName>HoldingsDaily</DataSetName>
          </Tablix>
        </ReportItems>
        <Height>3in</Height>
      </Body>
      <Width>7in</Width>
    </ReportSection>
  </ReportSections>

  <rd:ReportUnitType>Inch</rd:ReportUnitType>
</Report>
