# =========================================================================
# brighthive-platform-core — LOCAL development environment
# Generated by `make env-platform-core-local NAME=<you>` from vault.
# DO NOT EDIT BY HAND — run `FORCE=1 NAME=<you> make env-platform-core-local` to regenerate.
#
# Runs npm run deploy:local (ts-node src/servers/local.ts) on port 4040.
# Connects to Staging Neo4j and Redis — no local DB needed.
# LOCAL_DEV_MODE=true bypasses Cognito JWT validation.
# =========================================================================

# ── Local dev flags ──────────────────────────────────────────
LOCAL_DEV_MODE=true
ENV=LOCAL

# ── Neo4j (Staging — bolt+ssc) ───────────────────────────────
DB_URI={{ aws.staging.neo4j_uri }}
DB_USERNAME={{ aws.staging.neo4j_username }}
DB_PASSWORD={{ aws.staging.neo4j_password }}

# ── Redis (Staging) ──────────────────────────────────────────
REDIS_HOST={{ aws.staging.redis_host }}
REDIS_PORT=6379
REDIS_PASSWORD={{ aws.staging.redis_password }}

# ── Cognito (Staging — for JWKS validation) ──────────────────
USER_POOL_ID={{ aws.staging.user_pool_id }}
USER_POOL_CLIENT_ID={{ aws.staging.user_pool_client_id }}
JWKS_ENDPOINT=https://cognito-idp.us-east-1.amazonaws.com/{{ aws.staging.user_pool_id }}/.well-known/jwks.json

# ── Stream.io ────────────────────────────────────────────────
STREAM_KEY={{ aws.staging.stream_key }}
STREAM_SECRET=FILL_MANUALLY

# ── OpenMetadata (Staging) ───────────────────────────────────
OPENMETADATA_API_URL={{ aws.staging.ogm_url }}
OPENMETADATA_JWT=FILL_MANUALLY
OPENMETADATAV2_API_URL={{ aws.staging.ogm_url }}
OPENMETADATAV2_JWT=FILL_MANUALLY

# ── AWS (profile-based auth) ─────────────────────────────────
AWS_REGION=us-east-1
AWS_PROFILE=brighthive-staging

# ── Remaining (static / manual) ──────────────────────────────
DBT_API_URL=
DBT_TOKEN=FILL_MANUALLY
DATAPIARY_API_URL=
SENDGRID_API_KEY=FILL_MANUALLY
CLOUDFLARE_TURNSTILE_SECRET=FILL_MANUALLY
STATIC_ASSET_BUCKET_NAME=bh-staging-assets
STATIC_ASSET_DISTRIBUTION_DOMAIN_NAME=
GITHUB_CLIENT_ID=FILL_MANUALLY
NOTIFICATION_EMAIL=
