VITE_BRIGHTIBOT_API_KEY={{ aws.staging.langgraph_api_key }}
VITE_COLIBRI_BASE_URL=http://127.0.0.1:2024
VITE_COLIBRI_API_KEY={{ aws.staging.langgraph_api_key }}

# -------------------------------------------------------------------------
# Third-party integrations
# -------------------------------------------------------------------------
VITE_STREAM_KEY={{ aws.staging.stream_key }}
VITE_SLACK_SERVER_URL=https://slack.staging.brighthive.net
VITE_PYLON_APP_ID=7e4a02f1-0528-4fd2-a74c-8d20a3f52b28

