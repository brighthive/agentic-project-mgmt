# =========================================================================
# brighthive-webapp — STAGING development environment
# Generated by `make env-webapp-staging` from cached vault secrets.
# DO NOT EDIT BY HAND — run `make env-webapp-staging FORCE=1` to regenerate.
# =========================================================================

# -------------------------------------------------------------------------
# Platform APIs
# -------------------------------------------------------------------------
VITE_GRAPHQL_URL={{ aws.staging.apollo_url }}
VITE_LOCAL_DEV=false
VITE_MOCKS_ENABLED=false

# -------------------------------------------------------------------------
# BrightAgent / BrightBot
# -------------------------------------------------------------------------
VITE_BASE_URL={{ aws.staging.langgraph_base_url }}
VITE_BB_ASSISTANT_URL={{ aws.staging.langgraph_base_url }}
VITE_BRIGHTIBOT_API_KEY={{ aws.staging.langgraph_api_key }}
VITE_COLIBRI_BASE_URL={{ aws.staging.langgraph_base_url }}
VITE_COLIBRI_API_KEY={{ aws.staging.langgraph_api_key }}

# MCP server (curated FastMCP) — separate hostname from VITE_BB_ASSISTANT_URL
# because LangGraph Cloud's runtime claims /mcp inside the brightbot container
# and shadows our FastMCP. CloudFront on this hostname rewrites /mcp -> /bh-mcp
# internally so customers see clean /mcp. Webapp WorkspaceSettings/MCPConnectivityCard
# reads this directly (do NOT derive from VITE_BB_ASSISTANT_URL).
VITE_MCP_URL=https://brightagent-mcp.staging.brighthive.net/mcp

# -------------------------------------------------------------------------
# Third-party integrations
# -------------------------------------------------------------------------
VITE_STREAM_KEY={{ aws.staging.stream_key }}
VITE_SLACK_SERVER_URL=https://slack.staging.brighthive.net
VITE_PYLON_APP_ID=7e4a02f1-0528-4fd2-a74c-8d20a3f52b28

# -------------------------------------------------------------------------
# Feature flags
# -------------------------------------------------------------------------
VITE_ROUTE_VISIBILITY_CONFIG={"*":{"enabledRoutes":["Ingestion","Files","Sessions"]}}
