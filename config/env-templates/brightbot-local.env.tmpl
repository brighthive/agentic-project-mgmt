# =========================================================================
# brightbot — LOCAL development environment
# Generated by `make env-brightbot-local` from cached vault secrets.
# DO NOT EDIT BY HAND — run `make env-brightbot-local FORCE=1` to regenerate.
# Manual edits are detected via SHA and will block re-render until resolved.
# =========================================================================

# -------------------------------------------------------------------------
# LLM API Keys (from LastPass)
# -------------------------------------------------------------------------
OPENAI_API_KEY={{ lastpass.openai_api_key }}
ANTHROPIC_API_KEY={{ lastpass.anthropic_api_key }}
GROQ_API_KEY={{ lastpass.groq_api_key }}
DEEPSEEK_API_KEY={{ lastpass.deepseek_api_key }}
GOOGLE_API_KEY={{ lastpass.google_api_key }}

# -------------------------------------------------------------------------
# LangChain / LangSmith (slated for removal per BH-457 — kept for now)
# -------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY={{ lastpass.langsmith_api_key }}
LANGCHAIN_PROJECT=brightbot-local
LANGCHAIN_HUB_API_URL=https://api.hub.langchain.com
LANGCHAIN_HUB_API_KEY={{ lastpass.langchain_hub_api_key }}

# -------------------------------------------------------------------------
# Third-Party Services (LastPass)
# -------------------------------------------------------------------------
E2B_API_KEY={{ lastpass.e2b_api_key }}
TAVILY_API_KEY={{ lastpass.tavily_api_key }}
ADEPTID_API_KEY={{ lastpass.adeptid_api_key }}
SKILLUP_API_KEY={{ lastpass.skillup_api_key }}
MEM0_API_KEY={{ lastpass.mem0_api_key }}
MEM0_ORG_ID={{ lastpass.mem0_org_id }}
MEM0_PROJECT_ID={{ lastpass.mem0_project_id }}
GITHUB_CLIENT_ID={{ lastpass.brightbot_github_client_id }}

# -------------------------------------------------------------------------
# Cloudflare (LastPass)
# -------------------------------------------------------------------------
CLOUDFLARE_AUTH_TOKEN={{ lastpass.cloudflare_auth_token }}
CLOUDFLARE_ACCOUNT_ID={{ lastpass.cloudflare_account_id }}

# -------------------------------------------------------------------------
# AWS — local-dev mode (LocalStack endpoints, real Bedrock via SSO profile)
# -------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_PROFILE=${AWS_STAGING_PROFILE}
# Local-dev: AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY omitted on purpose;
# brightbot will use the AWS_PROFILE for SSO-backed credential resolution.

# -------------------------------------------------------------------------
# BrightHive Platform Core API (Staging — local-dev points at Staging API)
# -------------------------------------------------------------------------
BH_API_URL=https://api.staging.brighthive.net/
BH_USERNAME={{ aws.staging.brightbot_service_user_username }}
BH_PASSWORD={{ aws.staging.brightbot_service_user_password }}

# -------------------------------------------------------------------------
# Cognito (Staging User Pool — for local-dev BrightAgent auth)
# -------------------------------------------------------------------------
USER_POOL_ID={{ aws.staging.cognito_user_pool_id }}
USER_POOL_CLIENT_ID={{ aws.staging.cognito_user_pool_client_id }}

# -------------------------------------------------------------------------
# Neo4j (Staging — read-only for local-dev queries)
# -------------------------------------------------------------------------
NEO4J_URI={{ aws.staging.neo4j_uri }}
NEO4J_USERNAME={{ aws.staging.neo4j_username }}
NEO4J_PASSWORD={{ aws.staging.neo4j_password }}

# -------------------------------------------------------------------------
# OGM (OpenMetadata) — Staging
# -------------------------------------------------------------------------
OGM_URL={{ aws.staging.ogm_url }}
OGM_USER={{ aws.staging.ogm_user }}
OGM_PASSWORD={{ aws.staging.ogm_password }}

# -------------------------------------------------------------------------
# Redis (Staging cache — read-only for local-dev)
# -------------------------------------------------------------------------
REDIS_HOST={{ aws.staging.redis_host }}
REDIS_PASSWORD={{ aws.staging.redis_password }}

# -------------------------------------------------------------------------
# Redshift (Staging — local-dev queries against Staging warehouse)
# -------------------------------------------------------------------------
REDSHIFT_HOST={{ aws.staging.redshift_host }}
REDSHIFT_PORT=5439
REDSHIFT_DATABASE={{ aws.staging.redshift_database }}
REDSHIFT_USER={{ aws.staging.redshift_user }}
REDSHIFT_PASSWORD={{ aws.staging.redshift_password }}

# -------------------------------------------------------------------------
# Slack server bridge (for local-dev BrightAgent → Slack delivery)
# -------------------------------------------------------------------------
SLACK_SERVER_API_KEY_BHAGENT={{ aws.staging.slack_server_api_key_bhagent }}
SLACK_AGENT_TIMEOUT_SECONDS=120

# -------------------------------------------------------------------------
# DBT (Staging dbt Cloud server)
# -------------------------------------------------------------------------
DBT_SERVER_URL=https://staging.brighthive.net/dbt

# -------------------------------------------------------------------------
# Jupyter MCP (Staging Jupyter stack)
# -------------------------------------------------------------------------
JUPYTER_LAB_URL={{ aws.staging.jupyter_lab_url }}
JUPYTER_TOKEN={{ aws.staging.jupyter_token }}
JUPYTER_MCP_SERVER_URL={{ aws.staging.jupyter_mcp_server_url }}
JUPYTER_MCP_API_KEY={{ aws.staging.jupyter_mcp_api_key }}

# -------------------------------------------------------------------------
# Feature flags & tunables (static — same in every env)
# -------------------------------------------------------------------------
LOCAL_DEV_MODE=true
ENABLE_VECTOR_SEARCH=true
FEATURE_FLAG_AIRBYTE_CUSTOM_AGENT=true
FEATURE_FLAG_CONNECTOR_SANDBOX_BEDROCK=true
MCP_OPENMETADATA_ENABLED=true
MCP_OPENMETADATA_OFFICIAL_ENABLED=false
OPENMETADATA_MCP_STRATEGY=hybrid
OPENMETADATA_TOOL_SET=full
PLATFORM_CORE_ALLOW_MUTATIONS=false
PLATFORM_CORE_TOOL_SET=full
HIGH_CONFIDENCE_THRESHOLD=0.85
MEDIUM_CONFIDENCE_THRESHOLD=0.65
AIRBYTE_CUSTOM_AGENT_MAX_TOKENS=8000
INGESTION_STATE_TABLE=brighthive-ingestion-state-staging
WHITELISTED_LANGSMITH_API_KEYS={{ lastpass.langsmith_api_key }}
