# =========================================================================
# brightbot — LOCAL development environment
# Generated by `make env-brightbot-local NAME=<you>` from cached vault secrets.
# DO NOT EDIT BY HAND — run `FORCE=1 NAME=<you> make env-brightbot-local` to regenerate.
# Manual edits are detected via SHA and will block re-render until resolved.
#
# KEY SOURCES:
#   ✓ aws.staging.*   — AWS Secrets Manager staging account (auto-pulled)
#   ✓ lastpass.*      — LastPass vault (auto-pulled)
#   ✎ MANUAL          — copy these from ../brightbot/.env_staging (not in vault)
# =========================================================================

# -------------------------------------------------------------------------
# LLM API Keys — MANUAL (copy from ../brightbot/.env_staging)
# These live as shared folder entries in LastPass, not as flat secrets.
# -------------------------------------------------------------------------
OPENAI_API_KEY=FILL_FROM_ENV_STAGING
ANTHROPIC_API_KEY=FILL_FROM_ENV_STAGING
GROQ_API_KEY=FILL_FROM_ENV_STAGING
DEEPSEEK_API_KEY=FILL_FROM_ENV_STAGING
GOOGLE_API_KEY=FILL_FROM_ENV_STAGING

# -------------------------------------------------------------------------
# LangSmith — MANUAL (copy from ../brightbot/.env_staging, slated for removal per BH-457)
# -------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=FILL_FROM_ENV_STAGING
LANGCHAIN_PROJECT=brightbot-local
LANGCHAIN_HUB_API_URL=https://api.hub.langchain.com
LANGCHAIN_HUB_API_KEY=FILL_FROM_ENV_STAGING

# -------------------------------------------------------------------------
# Third-Party Services — MANUAL (copy from ../brightbot/.env_staging)
# -------------------------------------------------------------------------
E2B_API_KEY=FILL_FROM_ENV_STAGING
TAVILY_API_KEY=FILL_FROM_ENV_STAGING
ADEPTID_API_KEY=FILL_FROM_ENV_STAGING
SKILLUP_API_KEY=FILL_FROM_ENV_STAGING
MEM0_API_KEY=FILL_FROM_ENV_STAGING
MEM0_ORG_ID=FILL_FROM_ENV_STAGING
MEM0_PROJECT_ID=FILL_FROM_ENV_STAGING

# -------------------------------------------------------------------------
# Cloudflare — MANUAL (copy from ../brightbot/.env_staging)
# -------------------------------------------------------------------------
CLOUDFLARE_AUTH_TOKEN=FILL_FROM_ENV_STAGING
CLOUDFLARE_ACCOUNT_ID=FILL_FROM_ENV_STAGING

# -------------------------------------------------------------------------
# GitHub — MANUAL (copy from ../brightbot/.env_staging)
# -------------------------------------------------------------------------
GITHUB_CLIENT_ID=FILL_FROM_ENV_STAGING

# -------------------------------------------------------------------------
# AWS — profile-based auth (no keys in local-dev)
# -------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_PROFILE=brighthive-staging

# -------------------------------------------------------------------------
# BrightHive Platform Core API (Staging — local-dev points at Staging API)
# -------------------------------------------------------------------------
BH_API_URL=https://api.staging.brighthive.net/
BH_USERNAME={{ aws.staging.brightbot_service_user_username }}
BH_PASSWORD={{ aws.staging.brightbot_service_user_password }}

# -------------------------------------------------------------------------
# Cognito (Staging User Pool)
# -------------------------------------------------------------------------
USER_POOL_ID={{ aws.staging.user_pool_id }}
USER_POOL_CLIENT_ID={{ aws.staging.user_pool_client_id }}

# -------------------------------------------------------------------------
# Neo4j (Staging)
# -------------------------------------------------------------------------
NEO4J_URI={{ aws.staging.neo4j_uri }}
NEO4J_USERNAME={{ aws.staging.neo4j_username }}
NEO4J_PASSWORD={{ aws.staging.neo4j_password }}

# -------------------------------------------------------------------------
# OGM (OpenMetadata) — Staging
# -------------------------------------------------------------------------
OGM_URL={{ aws.staging.ogm_url }}
OGM_USER={{ aws.staging.ogm_admin_username }}
OGM_PASSWORD={{ aws.staging.ogm_admin_password }}

# -------------------------------------------------------------------------
# Redis (Staging)
# -------------------------------------------------------------------------
REDIS_HOST={{ aws.staging.redis_host }}
REDIS_PASSWORD={{ aws.staging.redis_password }}

# -------------------------------------------------------------------------
# Redshift — MANUAL (copy from ../brightbot/.env_staging)
# Not stored in Secrets Manager; in per-workspace configs
# -------------------------------------------------------------------------
REDSHIFT_HOST=FILL_FROM_ENV_STAGING
REDSHIFT_PORT=5439
REDSHIFT_DATABASE=FILL_FROM_ENV_STAGING
REDSHIFT_USER=FILL_FROM_ENV_STAGING
REDSHIFT_PASSWORD=FILL_FROM_ENV_STAGING

# -------------------------------------------------------------------------
# Slack server API key — MANUAL (copy from ../brightbot/.env_staging)
# -------------------------------------------------------------------------
SLACK_SERVER_API_KEY_BHAGENT=FILL_FROM_ENV_STAGING
SLACK_AGENT_TIMEOUT_SECONDS=120

# -------------------------------------------------------------------------
# DBT
# -------------------------------------------------------------------------
DBT_SERVER_URL=https://staging.brighthive.net/dbt

# -------------------------------------------------------------------------
# Jupyter — MANUAL (copy from ../brightbot/.env_staging)
# -------------------------------------------------------------------------
JUPYTER_LAB_URL=FILL_FROM_ENV_STAGING
JUPYTER_TOKEN=FILL_FROM_ENV_STAGING
JUPYTER_MCP_SERVER_URL=FILL_FROM_ENV_STAGING
JUPYTER_MCP_API_KEY=FILL_FROM_ENV_STAGING

# -------------------------------------------------------------------------
# Feature flags & tunables (static)
# -------------------------------------------------------------------------
LOCAL_DEV_MODE=true
ENABLE_VECTOR_SEARCH=true
FEATURE_FLAG_AIRBYTE_CUSTOM_AGENT=true
FEATURE_FLAG_CONNECTOR_SANDBOX_BEDROCK=true
MCP_OPENMETADATA_ENABLED=true
MCP_OPENMETADATA_OFFICIAL_ENABLED=false
OPENMETADATA_MCP_STRATEGY=hybrid
OPENMETADATA_TOOL_SET=full
PLATFORM_CORE_ALLOW_MUTATIONS=false
PLATFORM_CORE_TOOL_SET=full
HIGH_CONFIDENCE_THRESHOLD=0.85
MEDIUM_CONFIDENCE_THRESHOLD=0.65
AIRBYTE_CUSTOM_AGENT_MAX_TOKENS=8000
INGESTION_STATE_TABLE=brighthive-ingestion-state-staging
