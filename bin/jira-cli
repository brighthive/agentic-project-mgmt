#!/usr/bin/env bash
set -euo pipefail

# Thin shim → scripts/jira_cli. Resolves the repo root so users can call
# `bin/jira-cli` from anywhere via $PATH or via `make ticket`.

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

if [[ -z "${VIRTUAL_ENV:-}" ]] && [[ -d "${REPO_ROOT}/.venv" ]]; then
  # shellcheck disable=SC1091
  source "${REPO_ROOT}/.venv/bin/activate"
fi

if ! python -c "import httpx" >/dev/null 2>&1; then
  echo "[jira-cli] httpx not installed — run: uv pip install -r ${REPO_ROOT}/scripts/jira_cli/requirements.txt" >&2
  exit 4
fi

cd "${REPO_ROOT}"
exec python -m scripts.jira_cli "$@"
