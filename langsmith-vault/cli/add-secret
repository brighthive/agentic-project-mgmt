#!/usr/bin/env python3
"""Safely ADD a single secret to a LangSmith / LangGraph Cloud deployment.

`PATCH /v2/deployments/{id}` REPLACES the entire `secrets` array (2026-06-18: a
partial payload wiped brightagent-staging 74 -> 1). This tool never sends a partial
payload: it GETs the full array, appends ONE new entry in memory, asserts the new
count is exactly old+1, and PATCHes the complete reconstructed array. Dry-run by
default — mutation requires --apply.

Verified precondition (2026-07-24): GET returns {name, value} with values populated
for every entry, so full reconstruction is loss-less. This tool RE-CHECKS that
invariant at runtime and refuses to PATCH if any existing entry has an empty value.

Usage:
    # dry-run (default) — shows what WOULD change, mutates nothing:
    LANGCHAIN_API_KEY=... ./cli/add-secret --deployment-id <id> --name FOO --value-stdin < value.txt
    # apply:
    LANGCHAIN_API_KEY=... ./cli/add-secret --deployment-id <id> --name FOO --value-stdin --apply < value.txt

The value is read from stdin (--value-stdin) so it never lands in shell history or argv.
"""
from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys

LANGSMITH_HOST = os.environ.get("LANGSMITH_HOST", "https://api.host.langchain.com")


def api_key() -> str:
    key = os.environ.get("LANGCHAIN_API_KEY") or os.environ.get("LANGSMITH_API_KEY")
    if not key:
        sys.exit("ERROR: LANGCHAIN_API_KEY (or LANGSMITH_API_KEY) not set")
    return key


def _curl(method: str, path: str, body: str | None = None) -> tuple[int, str]:
    """Shell out to curl. Returns (http_status, body_text)."""
    url = f"{LANGSMITH_HOST}{path}"
    cmd = [
        "curl", "-sS", "--max-time", "30",
        "-X", method,
        "-H", f"X-API-Key: {api_key()}",
        "-H", "Accept: application/json",
        "-w", "\n%{http_code}",
    ]
    if body is not None:
        cmd += ["-H", "Content-Type: application/json", "--data-binary", "@-"]
    cmd.append(url)
    result = subprocess.run(cmd, input=body, capture_output=True, text=True)
    if result.returncode != 0:
        sys.exit(f"ERROR: curl transport failure for {method} {url}\n{result.stderr}")
    out = result.stdout
    nl = out.rfind("\n")
    status = int(out[nl + 1:].strip() or "0")
    return status, out[:nl]


def get_deployment(deployment_id: str) -> dict:
    status, text = _curl("GET", f"/v2/deployments/{deployment_id}")
    if status != 200:
        sys.exit(f"ERROR: GET deployment {deployment_id} returned {status}\n{text[:400]}")
    return json.loads(text)


def main() -> None:
    parser = argparse.ArgumentParser(description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter)
    parser.add_argument("--deployment-id", required=True, help="LangSmith deployment UUID")
    parser.add_argument("--name", required=True, help="secret name to add")
    parser.add_argument("--value-stdin", action="store_true", required=True,
                        help="read the secret value from stdin (keeps it out of argv/history)")
    parser.add_argument("--apply", action="store_true",
                        help="actually PATCH (default is dry-run — no mutation)")
    args = parser.parse_args()

    value = sys.stdin.read().strip()
    if not value:
        sys.exit("ERROR: empty value on stdin — refusing to add an empty secret")

    dep = get_deployment(args.deployment_id)
    name = dep.get("name")
    secrets = dep.get("secrets") or []
    old_count = len(secrets)
    existing_names = [s.get("name") for s in secrets]

    # Invariant re-check: reconstruction is only loss-less if every existing entry
    # carries a value. If the API ever returns names-only, ABORT before any PATCH.
    empty_valued = [s.get("name") for s in secrets if not s.get("value")]
    if empty_valued:
        sys.exit(
            f"ABORT: {len(empty_valued)} existing secret(s) have EMPTY values on GET "
            f"({empty_valued[:5]}...). Reconstruction would WIPE them. Refusing to PATCH."
        )

    if args.name in existing_names:
        sys.exit(f"ABORT: secret {args.name!r} already exists on {name} — this tool only ADDS. Nothing to do.")

    reconstructed = list(secrets) + [{"name": args.name, "value": value}]
    new_count = len(reconstructed)
    assert new_count == old_count + 1, f"count math wrong: {new_count} != {old_count}+1"

    print(f"deployment:      {name} ({args.deployment_id})")
    print(f"host:            {LANGSMITH_HOST}")
    print(f"existing count:  {old_count} (all values present ✅)")
    print(f"adding:          {args.name} (value len={len(value)}, not shown)")
    print(f"new count:       {new_count}")

    if not args.apply:
        print("\nDRY-RUN — no mutation performed. Re-run with --apply to PATCH.")
        return

    # PATCH the COMPLETE reconstructed array — never a partial payload.
    payload = json.dumps({"secrets": reconstructed})
    status, text = _curl("PATCH", f"/v2/deployments/{args.deployment_id}", body=payload)
    if status not in (200, 202):
        sys.exit(f"ERROR: PATCH returned {status}\n{text[:400]}")
    print(f"PATCH -> {status}")

    # Verify: re-GET and assert the new count + presence.
    after = get_deployment(args.deployment_id)
    after_secrets = after.get("secrets") or []
    after_names = [s.get("name") for s in after_secrets]
    if len(after_secrets) != new_count:
        sys.exit(f"POST-CHECK FAILED: expected {new_count} secrets, got {len(after_secrets)} — INVESTIGATE NOW.")
    if args.name not in after_names:
        sys.exit(f"POST-CHECK FAILED: {args.name!r} not present after PATCH — INVESTIGATE NOW.")
    print(f"VERIFIED: {name} now has {len(after_secrets)} secrets incl. {args.name}. ✅")


if __name__ == "__main__":
    main()
